{
  "name": "pi-hybrid-harness",
  "version": "0.3.0",
  "description": "Pi package for frontier-designed, local-LLM implementation loops with frontier final gates.",
  "keywords": [
    "pi-package",
    "pi",
    "hybrid",
    "local-llm",
    "orchestration"
  ],
  "license": "MIT",
  "type": "module",
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "test": "npm run typecheck && node --test",
    "test:unit": "node --test",
    "pack:dry": "npm pack --dry-run",
    "cli": "node ./bin/pi-hybrid-harness.js"
  },
  "bin": {
    "pi-hybrid-harness": "bin/pi-hybrid-harness.js"
  },
  "files": [
    "extensions",
    "src",
    "skills",
    "bin",
    "README.md",
    "package.json"
  ],
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
